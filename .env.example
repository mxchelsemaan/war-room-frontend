# Telegram — from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_STRING=your_session_string_here

# Optional: earliest date for first-run backfill (ISO date, e.g. 2026-02-27)
# Leave empty to fetch latest first_run_limit messages instead.
TELEGRAM_MIN_DATE=

# Twitter/X — Bearer token from https://developer.twitter.com
# Requires Basic tier ($100/month) or higher.
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Supabase — from https://supabase.com/dashboard/project/<project>/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Prefect Cloud — from https://app.prefect.cloud/my/api-keys
# PREFECT_API_URL: Settings > Workspaces > API URL
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/<account-id>/workspaces/<workspace-id>
PREFECT_API_KEY=your_prefect_api_key_here
